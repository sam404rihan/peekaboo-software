rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---------------------------------------------------------------
    // Core helpers
    // ---------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    // Returns the role stored in the Users doc, defaults to 'admin'
    // during bootstrap (before the doc is created).
    function userRole() {
      let u = get(/databases/$(database)/documents/Users/$(request.auth.uid));
      return u.data.role != null ? u.data.role : 'admin';
    }

    // Admin: signed in AND role is 'admin'
    function isAdmin() {
      return isSignedIn() && userRole() == 'admin';
    }

    // Staff: any signed-in user (admin or cashier)
    function isStaff() {
      return isSignedIn();
    }

    // ---------------------------------------------------------------
    // Field validators (used for cashier-only paths)
    // ---------------------------------------------------------------
    function isNonNeg(n) {
      return n is number && n >= 0;
    }

    function isPct(n) {
      return n is number && n >= 0 && n <= 100;
    }

    function onlyChanges(keys) {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly(keys);
    }

    // ---------------------------------------------------------------
    // Users
    // ---------------------------------------------------------------
    match /Users/{uid} {
      allow read: if isStaff();

      // Bootstrap: user creates their own doc on first sign-in
      allow create: if isSignedIn() && uid == request.auth.uid;

      // Admin: full control; user can update their own safe fields
      allow update: if isAdmin() ||
        (isSignedIn() && uid == request.auth.uid &&
         onlyChanges(['displayName', 'lastLoginAt', 'updatedAt', 'email']));

      allow delete: if isAdmin();
    }

    // ---------------------------------------------------------------
    // Settings
    // ---------------------------------------------------------------
    match /Settings/{id} {
      allow read: if isStaff();
      // Admin: unrestricted
      allow write: if isAdmin();
      // Cashier: only bump invoice sequence
      allow update: if isStaff() &&
        onlyChanges(['nextInvoiceSequence', 'updatedAt']) &&
        request.resource.data.nextInvoiceSequence is number &&
        request.resource.data.nextInvoiceSequence >= resource.data.nextInvoiceSequence;
    }

    // ---------------------------------------------------------------
    // Products  ← this was blocking the Excel upload
    // ---------------------------------------------------------------
    match /Products/{id} {
      allow read: if isStaff();
      // Admin: full read/write, no field validation (trusted user)
      allow create, update, delete: if isAdmin();
      // Cashier: can only adjust stock and label count
      allow update: if isStaff() &&
        onlyChanges(['stock', 'printedCount', 'updatedAt']) &&
        isNonNeg(request.resource.data.stock);
    }

    // ---------------------------------------------------------------
    // Categories
    // ---------------------------------------------------------------
    match /Categories/{id} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    // ---------------------------------------------------------------
    // Customers
    // ---------------------------------------------------------------
    match /Customers/{id} {
      allow read: if isStaff();
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    // ---------------------------------------------------------------
    // Invoices
    // ---------------------------------------------------------------
    match /Invoices/{id} {
      allow read: if isStaff();
      // Admin: full control
      allow write: if isAdmin();
      // Cashier: create invoices; update only payment/status fields
      allow create: if isStaff() &&
        request.resource.data.cashierUserId == request.auth.uid &&
        isNonNeg(request.resource.data.subtotal) &&
        isNonNeg(request.resource.data.grandTotal) &&
        request.resource.data.items is list &&
        request.resource.data.items.size() > 0 &&
        request.resource.data.status in ['paid', 'partial', 'unpaid', 'void'];
      allow update: if isStaff() &&
        onlyChanges(['payments', 'balanceDue', 'status', 'updatedAt']) &&
        request.resource.data.status in ['paid', 'partial', 'unpaid', 'void'];
    }

    // ---------------------------------------------------------------
    // Inventory Logs
    // ---------------------------------------------------------------
    match /InventoryLogs/{id} {
      allow read: if isStaff();
      // Admin: full control
      allow write: if isAdmin();
      // Cashier: create log entries only
      allow create: if isStaff() &&
        request.resource.data.productId is string &&
        request.resource.data.type in ['adjustment', 'sale', 'purchase', 'return', 'damage'] &&
        request.resource.data.quantityChange is number;
    }

    // ---------------------------------------------------------------
    // Goods Receipts
    // ---------------------------------------------------------------
    match /GoodsReceipts/{id} {
      allow read: if isStaff();
      allow write: if isAdmin();
      allow create: if isStaff() &&
        request.resource.data.createdByUserId == request.auth.uid;
    }

    // ---------------------------------------------------------------
    // Offers
    // ---------------------------------------------------------------
    match /Offers/{id} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    // ---------------------------------------------------------------
    // Barcodes
    // ---------------------------------------------------------------
    match /Barcodes/{id} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    // ---------------------------------------------------------------
    // Reports
    // ---------------------------------------------------------------
    match /Reports/{id} {
      allow read, write: if isAdmin();
    }

    // ---------------------------------------------------------------
    // Exchanges & Refunds
    // ---------------------------------------------------------------
    match /Exchanges/{id} {
      allow read: if isStaff();
      allow write: if isAdmin();
      allow create: if isStaff();
    }

    match /Refunds/{id} {
      allow read: if isStaff();
      allow write: if isAdmin();
      allow create: if isStaff();
    }

    // ---------------------------------------------------------------
    // Default deny
    // ---------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
